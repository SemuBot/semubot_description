<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="head_macro" params="parent xyz rpy">

    <!-- Head Base -->
    <link name="head_base">
      <visual>
        <geometry>
          <mesh filename="package://semubot_description/meshes/head_base.stl" scale="1 1 1"/>
        </geometry>
        <material name="white"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.06" length="0.1"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.4"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>
    
    <joint name="head_joint" type="revolute">
      <parent link="${parent}"/>
      <child link="head_base"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
    </joint>

    <!-- Head Scalp -->
    <link name="head_scalp">
      <visual>
        <geometry>
          <mesh filename="package://semubot_description/meshes/head_scalp.stl" scale="1 1 1"/>
        </geometry>
        <material name="cyan"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.12" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.12"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.2"/>
        <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
      </inertial>
    </link>

    <joint name="head_scalp_joint" type="fixed">
      <parent link="head_base"/>
      <child link="head_scalp"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Head Screen -->
    <link name="head_screen">
      <visual>
        <geometry>
          <mesh filename="package://semubot_description/meshes/head_screen.stl" scale="1 1 1"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.1 0.01 0.08"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.2"/>
        <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
      </inertial>
    </link>

    <joint name="head_screen_joint" type="fixed">
      <parent link="head_base"/>
      <child link="head_screen"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

</robot>